# Notion API
# 1. https://www.notion.so/my-integrations でIntegrationを作成
# 2. 作成したIntegrationのAPIキーをここに設定
# 3. Notionの「W杯2026 ブログ記事」データベースにIntegrationを招待（共有→コネクトを追加）
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxx

# Notionデータベース ID
# データベースのURLからIDを取得: https://www.notion.so/xxxxxxxx?v=yyyyyyyy の xxxxxxxx 部分
NOTION_DATABASE_ID=72c16e8e3e214ae9834b4e740a7a8772

# プロモバナー管理データベース ID
NOTION_PROMO_DATABASE_ID=6417346b1c3e4423bddd0239be5aa261

# ================================================
# チーム・監督マスタデータ（scripts/seedTeams.ts / syncTeams.ts 用）
# ================================================
# マスタページ: https://www.notion.so/34327709231f816c9209d467cb448d8f
# 各 DB に Integration を接続（共有→コネクトを追加）してから使用してください
NOTION_TEAMS_DATABASE_ID=cd7b0a3ffffc46babac1acbcef1352a9
NOTION_TEAM_DETAILS_DATABASE_ID=9b83b855018f4d50af8132d3ae0fbf27
NOTION_COACHES_DATABASE_ID=aedabbe6488545c886a1f2735a736e20

# ================================================
# IndexNow (Bing / Yandex 即時インデックス通知)
# ================================================
# 任意の8〜128文字の英数字（UUIDで可）。同じ値を public/{KEY}.txt として配置すること。
# Vercel本番にも同じ値を Environment Variables に登録（Production）してください。
INDEXNOW_KEY=abf29a8616ff4de8a6aba1aaed224d30
